  "root_cause_analysis": {
    "issue": "Type mismatch - passing int (frequency_hours) where datetime expected",
    "details": "Function validate_schedule_timing() calls _schedules_overlap() with med1.frequency_hours and med2.frequency_hours (both integers representing hours), but _schedules_overlap() expects datetime objects. The function signature shows parameters time1: dt.datetime and time2: dt.datetime, but integers are being passed instead.",
    "affected_code": "src/medication_tracker/schedule_validator.py:67",
    "expected_behavior": "Should pass actual datetime objects representing when medications are scheduled, or change _schedules_overlap() to accept frequency_hours integers",
    "actual_behavior": "Passes integers to function expecting datetime, causing TypeError when trying to subtract",
    "impact": "MEDIUM - Prevents schedule validation, blocks adding new medications",
    "design_flaw": {
      "issue": "Confusion between 'frequency' and 'scheduled time'",
      "frequency_hours": "How often medication is given (e.g., every 12 hours)",
      "scheduled_time": "Actual time medication is scheduled (e.g., 08:00, 20:00)",
      "current_code": "Tries to check overlap using frequency, not actual scheduled times",
      "correct_approach": "Should calculate actual scheduled times based on start_date and frequency, then check for overlaps"
